{
  "name": "peabrain",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "flash": "peabrain flash",
    "pcb:tpl": "kisch pcb/tpl/tpl.kicad_sch -s pcb/tpl/tpl.js -L /home/micke/Repo.ext/kicad-symbols/",
    "pcb:motor": "kisch pcb/motor/motor.kicad_sch -s pcb/motor/motor.js -L /home/micke/Repo.ext/kicad-symbols/",
    "pcb:liu": "kisch pcb/liu/liu.kicad_sch -s pcb/liu/liu.js -L /home/micke/Repo.ext/kicad-symbols/",
    "pcb:gpio": "kisch pcb/gpio/gpio.kicad_sch -s pcb/gpio/gpio.js -L /home/micke/Repo.ext/kicad-symbols/",
    "pcb:relay": "kisch pcb/relay/relay.kicad_sch -s pcb/relay/relay.js -L /home/micke/Repo.ext/kicad-symbols/",
    "pcb:discrete-motor": "kisch pcb/discrete-motor/discrete-motor.kicad_sch -s pcb/discrete-motor/discrete-motor.js -L /home/micke/Repo.ext/kicad-symbols/",
    "fab:relay": "kicad-fab-export pcb/relay/relay.kicad_pcb -o pcb/relay/jlcpcb -F /home/micke/Repo.ext/kicad-footprints/",
    "fab:gpio": "kicad-fab-export pcb/gpio/gpio.kicad_pcb -F /home/micke/Repo.ext/kicad-footprints/",
    "fab:liu": "kicad-fab-export pcb/liu/liu.kicad_pcb -F /home/micke/Repo.ext/kicad-footprints/",
    "fab:discrete-motor": "kicad-fab-export pcb/discrete-motor/discrete-motor.kicad_pcb -F /home/micke/Repo.ext/kicad-footprints/"
  },
  "bin": {
    "peabrain": "js/tools/peabrain-cli.js"
  },
  "packages": "packages",
  "exports": {
    ".": {
      "mcu": "./js/exports/exports-mcu.js"
    },
    "./peakernel-project-hooks": "./js/tools/peabrain-commands.js"
  },
  "type": "module",
  "keywords": [
    "peakernel-plugin"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "canopener": "^1.0.0",
    "commander": "^14.0.3",
    "peakernel": "^1.0.0"
  },
  "devDependencies": {
    "kisch": "^1.0.5"
  }
}
